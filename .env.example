# Copy this file to .env.production (or supply these via your CI/CD secrets)
# and fill in real values before running docker compose.

# PostgreSQL credentials
POSTGRES_DB=hakerek
POSTGRES_USER=hakerek
POSTGRES_PASSWORD=change-me

# Full connection URL used by Prisma and the app
DATABASE_URL=postgresql://hakerek:change-me@postgres:5432/hakerek

# NextAuth
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=https://your-domain.com
